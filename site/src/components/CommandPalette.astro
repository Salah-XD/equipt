---
---
<div class="cmdk" data-cmdk hidden>
  <div class="cmdk-backdrop" data-cmdk-close></div>
  <div class="cmdk-panel" role="dialog" aria-modal="true" aria-label="Search skills and agents" data-lenis-prevent>
    <div class="cmdk-bar">
      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4-4"/></svg>
      <input class="cmdk-input" type="search" placeholder="Search 607 skills & agents…" aria-label="Search skills and agents" autocomplete="off" spellcheck="false" />
    </div>
    <ul class="cmdk-results" role="listbox" aria-label="Results"></ul>
    <div class="cmdk-foot mono"><span><kbd>↑</kbd><kbd>↓</kbd> navigate</span><span><kbd>↵</kbd> open</span><span><kbd>esc</kbd> close</span></div>
  </div>
</div>
<style>
  /* Container chrome — these elements live in the template, so scoped styles reach them. */
  .cmdk { position: fixed; inset: 0; z-index: 200; display: flex; align-items: flex-start; justify-content: center; }
  .cmdk[hidden] { display: none; }
  .cmdk-backdrop { position: absolute; inset: 0; background: rgba(13, 10, 6, .55); backdrop-filter: blur(3px); }
  .cmdk-panel { position: relative; margin-top: 12vh; width: min(620px, 92vw); max-height: 70vh; display: flex; flex-direction: column;
    background: var(--paper); border: 1px solid var(--hair); border-radius: 14px; box-shadow: 0 30px 80px -30px rgba(0,0,0,.5); overflow: hidden; }
  .cmdk-bar { display: flex; align-items: center; gap: 11px; padding: 15px 17px; border-bottom: 1px solid var(--hair); color: var(--muted); }
  .cmdk-input { flex: 1; border: none; background: transparent; color: var(--ink); font-family: var(--font-body); font-size: 16px; outline: none; }
  .cmdk-results { list-style: none; overflow-y: auto; padding: 6px; margin: 0; }
  .cmdk-foot { display: flex; gap: 16px; padding: 10px 16px; border-top: 1px solid var(--hair); color: var(--muted); font-size: 11px; }
  .cmdk-foot kbd { border: 1px solid var(--hair); border-radius: 4px; padding: 1px 5px; margin-right: 2px; }
</style>
<style is:global>
  /* Result rows are injected by client JS (innerHTML), so scoped styles can't reach
     them. Global, but namespaced under .cmdk-results so they can't leak elsewhere. */
  .cmdk-results .cmdk-item { display: grid; grid-template-columns: auto 1fr auto; align-items: baseline; gap: 4px 10px; padding: 9px 11px; border-radius: 9px; cursor: pointer; }
  .cmdk-results .cmdk-item.sel { background: var(--page); }
  .cmdk-results .ci-k { grid-row: 1; font-family: var(--font-mono); font-size: 10px; text-transform: uppercase; letter-spacing: .04em; padding: 2px 7px; border-radius: 5px; border: 1px solid var(--hair); align-self: center; }
  .cmdk-results .k-skill { color: var(--accent-text); }
  .cmdk-results .k-agent { color: var(--ink); }
  .cmdk-results .ci-name { font-family: var(--font-display); font-size: 15px; }
  .cmdk-results .ci-score { font-family: var(--font-mono); font-size: 12px; color: var(--muted); }
  .cmdk-results .ci-desc { grid-column: 2 / 4; color: var(--muted); font-size: 12.5px; line-height: 1.4;
    display: -webkit-box; -webkit-line-clamp: 1; -webkit-box-orient: vertical; overflow: hidden; }
  .cmdk-results .cmdk-empty { padding: 22px; text-align: center; color: var(--muted); font-size: 14px; }
</style>
<script>
  const root = document.querySelector<HTMLElement>('[data-cmdk]');
  if (root) {
    const input = root.querySelector<HTMLInputElement>('.cmdk-input')!;
    const results = root.querySelector<HTMLUListElement>('.cmdk-results')!;
    let data: any[] = [];
    let fuse: any = null;
    let loaded = false;
    let sel = 0;
    const esc = (s: string) => s.replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c] as string));

    async function ensureData() {
      if (loaded) return;
      loaded = true;
      try {
        const [{ default: Fuse }, res] = await Promise.all([import('fuse.js'), fetch('/catalog-index.json')]);
        data = await res.json();
        fuse = new Fuse(data, { keys: [{ name: 'name', weight: 3 }, 'description'], threshold: 0.3, ignoreLocation: true });
      } catch {}
    }
    function current() {
      const q = input.value.trim();
      return q && fuse ? fuse.search(q).slice(0, 30).map((r: any) => r.item) : data.slice(0, 12);
    }
    function render() {
      const out = current();
      sel = 0;
      results.innerHTML = out.map((e: any, i: number) =>
        `<li role="option" class="cmdk-item${i === 0 ? ' sel' : ''}" data-href="/catalog/${e.slug}">`
        + `<span class="ci-k k-${e.kind}">${e.kind}</span>`
        + `<span class="ci-name">${esc(e.name)}</span>`
        + (e.readiness != null ? `<span class="ci-score">${e.readiness}</span>` : '<span></span>')
        + `<span class="ci-desc">${esc(e.description)}</span>`
        + `</li>`).join('') || '<li class="cmdk-empty">No matches.</li>';
    }
    function move(d: number) {
      const items = results.querySelectorAll<HTMLElement>('.cmdk-item');
      if (!items.length) return;
      items[sel]?.classList.remove('sel');
      sel = (sel + d + items.length) % items.length;
      items[sel].classList.add('sel');
      items[sel].scrollIntoView({ block: 'nearest' });
    }
    function go() {
      const href = results.querySelectorAll<HTMLElement>('.cmdk-item')[sel]?.dataset.href;
      if (href) location.href = href;
    }
    function open() {
      root!.hidden = false;
      document.documentElement.style.overflow = 'hidden';
      ensureData().then(render);
      requestAnimationFrame(() => input.focus());
    }
    function close() {
      root!.hidden = true;
      document.documentElement.style.overflow = '';
      input.value = '';
    }

    input.addEventListener('input', render);
    input.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowDown') { e.preventDefault(); move(1); }
      else if (e.key === 'ArrowUp') { e.preventDefault(); move(-1); }
      else if (e.key === 'Enter') { e.preventDefault(); go(); }
      else if (e.key === 'Escape') { close(); }
    });
    results.addEventListener('click', (e) => {
      const li = (e.target as HTMLElement).closest<HTMLElement>('.cmdk-item');
      if (li?.dataset.href) location.href = li.dataset.href;
    });
    root.querySelectorAll('[data-cmdk-close]').forEach((el) => el.addEventListener('click', close));
    document.addEventListener('keydown', (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') { e.preventDefault(); root.hidden ? open() : close(); }
    });
    document.querySelectorAll('[data-open-palette]').forEach((el) =>
      el.addEventListener('click', (e) => { e.preventDefault(); open(); }));
  }
</script>
