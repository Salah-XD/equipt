---
interface Props { total: number; }
const { total } = Astro.props;
const ICONS: Record<string, string> = {
  claude: '<svg viewBox="0 0 16 16" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M8 1.5v3M8 11.5v3M1.5 8h3M11.5 8h3M3.4 3.4l2.1 2.1M10.5 10.5l2.1 2.1M12.6 3.4l-2.1 2.1M5.5 10.5l-2.1 2.1"/></svg>',
  cursor: '<svg viewBox="0 0 16 16" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"><path d="M3 2.5l9.5 4-4 1.4-1.4 4z"/></svg>',
  codex: '<svg viewBox="0 0 16 16" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><rect x="1.8" y="3" width="12.4" height="10" rx="2"/><path d="M4.6 6.6l1.9 1.5-1.9 1.5M8.4 9.8h2.8"/></svg>',
  antigravity: '<svg viewBox="0 0 16 16" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"><path d="M8 1.6c.4 2.9 1.5 4 4.4 4.4-2.9.4-4 1.5-4.4 4.4-.4-2.9-1.5-4-4.4-4.4C6.5 5.6 7.6 4.5 8 1.6z"/></svg>',
};
const surfaces = [
  { label: 'claude.ai', live: true, icon: 'claude' },
  { label: 'Claude desktop', live: true, icon: 'claude' },
  { label: 'Claude Code', live: true, icon: 'claude' },
  { label: 'Cursor — soon', live: false, icon: 'cursor' },
  { label: 'Codex — soon', live: false, icon: 'codex' },
  { label: 'Antigravity — soon', live: false, icon: 'antigravity' },
];
---
<header class="hero">
  <div class="grid-layer" data-hero-grid aria-hidden="true"></div>
  <div class="wrap herowrap">
    <div class="hcontent">
      <p class="kicker">{total} verified skills &amp; agents · for founders &amp; operators</p>
      <h1 class="big">Equip<br />your <span class="pop">AI.</span></h1>
      <p class="serif">Marketing, sales, ops &amp; content — <i>handled</i>.</p>
      <p class="sub">A curated, <b>verified</b> library of AI skills &amp; agents for the work of running a business — marketing, sales, ops, finance, content. Add them to claude.ai in minutes, no code.</p>
      <div class="cta">
        <a class="b1" href="/catalog">Browse skills</a>
        <a class="b2" href="/#install">How to add to claude.ai</a>
      </div>
      <div class="surf">
        <span class="kicker surf-label">Works in</span>
        {surfaces.map((s) => <span class={`pill${s.live ? '' : ' soon'}`}><span class="ico" aria-hidden="true" set:html={ICONS[s.icon]} />{s.label}</span>)}
      </div>
    </div>

    <div class="hero-art" aria-hidden="true">
      <div class="art-stack">
        <div class="art-card art-back"></div>
        <div class="art-card art-front">
          <div class="ac-top"><span class="ac-k">AGENT</span><span class="ac-tier">Field-Ready · 98</span></div>
          <strong class="ac-name">cold-outreach-writer</strong>
          <p class="ac-desc">Cold DMs, emails &amp; call scripts that actually get replies — real personalization, not “I came across your profile.”</p>
          <div class="ac-axes">
            <span><i style="width:94%"></i></span>
            <span><i style="width:88%"></i></span>
            <span><i style="width:97%"></i></span>
          </div>
          <span class="ac-pl">equipt-marketing</span>
        </div>
        <div class="seal">
          <span class="seal-disc"></span>
          <svg class="seal-ring" viewBox="0 0 120 120" aria-hidden="true">
            <defs>
              <path id="seal-top" d="M 16,60 A 44,44 0 0 1 104,60" fill="none"/>
              <path id="seal-bot" d="M 16,60 A 44,44 0 0 0 104,60" fill="none"/>
            </defs>
            <text class="seal-txt"><textPath href="#seal-top" startOffset="50%">THE EQUIPT STANDARD</textPath></text>
            <text class="seal-txt"><textPath href="#seal-bot" startOffset="50%">VERIFIED</textPath></text>
            <circle class="seal-dot" cx="16" cy="60" r="1.5"/>
            <circle class="seal-dot" cx="104" cy="60" r="1.5"/>
          </svg>
          <span class="seal-core">
            <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12.5l5 5 11-12"/></svg>
          </span>
        </div>
      </div>
    </div>
  </div>
</header>
<style>
  .hero { position: relative; isolation: isolate; overflow: hidden;
    background: var(--paper); border-bottom: 1px solid var(--hair);
    padding: 56px 0 64px; }
  /* Signature moment: the brutalist grid is its own layer so it can parallax on scroll */
  .grid-layer { position: absolute; inset: -10% 0 -20% 0; z-index: -1; pointer-events: none;
    background-image: linear-gradient(var(--grid) 1px, transparent 1px), linear-gradient(90deg, var(--grid) 1px, transparent 1px);
    background-size: 54px 54px;
    will-change: transform; }
  .grid-layer::after { content: ''; position: absolute; inset: 0;
    background: radial-gradient(120% 90% at 12% 8%, transparent 40%, var(--paper) 100%); }

  .herowrap { display: grid; grid-template-columns: minmax(0, 1.08fr) minmax(0, .92fr); gap: 28px; align-items: center; }
  .kicker { margin-top: 0; }
  .big { font-family: var(--font-display); font-weight: 700; font-size: clamp(52px, 8.2vw, 104px);
    line-height: .85; letter-spacing: -.045em; margin-top: 30px; }
  .big .pop { color: var(--accent); }
  .serif { font-family: var(--font-serif); font-size: clamp(26px, 3.4vw, 38px); line-height: 1.04;
    letter-spacing: .02em; margin-top: 16px; }
  .serif i { color: var(--accent); }

  .sub { max-width: 460px; font-size: 16px; line-height: 1.6; color: var(--muted); margin-top: 26px; }
  .sub b { color: var(--ink); }
  .cta { display: flex; gap: 10px; margin-top: 22px; flex-wrap: wrap; }
  .b1, .b2 { font-weight: 600; font-size: 13px; letter-spacing: .005em; padding: 14px 20px; border-radius: 10px;
    transition: transform .18s cubic-bezier(.22,1,.36,1), background-color .18s ease, color .18s ease, box-shadow .18s ease; }
  .b1 { background: var(--ink); color: var(--paper); box-shadow: 0 1px 0 var(--hair); }
  .b1:hover { transform: translateY(-2px); box-shadow: 0 8px 20px -10px var(--accent-soft); background: var(--accent); }
  .b2 { border: 1px solid var(--ink); }
  .b2:hover { transform: translateY(-2px); border-color: var(--accent); color: var(--accent-text); }

  .surf { display: flex; gap: 8px; margin-top: 34px; flex-wrap: wrap; align-items: center; }
  .surf-label { margin-right: 6px; }
  .pill { display: inline-flex; align-items: center; gap: 7px; font-size: 12px; font-weight: 500;
    padding: 7px 13px 7px 11px; border-radius: 999px; border: 1px solid var(--hair); color: var(--muted); }
  .pill .ico { display: inline-flex; color: var(--accent); }
  .pill.soon { border-style: dashed; opacity: .72; }
  .pill.soon .ico { color: var(--muted); }

  /* ---- Hero art: a tilted "certified" asset card with a rotating Equipt Standard stamp ---- */
  .hero-art { display: grid; place-items: center; min-height: 380px; }
  .art-stack { position: relative; width: min(340px, 100%); animation: hfloat 7s ease-in-out infinite; }
  .art-card { border: 1px solid var(--hair); border-radius: 16px; background: var(--paper); }
  .art-front { position: relative; z-index: 2; padding: 22px 22px 20px; transform: rotate(-4deg);
    box-shadow: 0 30px 60px -28px rgba(0,0,0,.4), 0 2px 0 var(--hair); }
  .art-back { position: absolute; inset: 0; z-index: 1; transform: rotate(5deg) translate(14px, 12px);
    background: var(--page); opacity: .8; }
  .ac-top { display: flex; justify-content: space-between; align-items: center; gap: 10px; margin-bottom: 14px; }
  .ac-k { font-family: var(--font-mono); font-size: 10.5px; text-transform: uppercase; letter-spacing: .06em; color: var(--muted);
    padding: 3px 8px; border-radius: 6px; border: 1px solid var(--hair); }
  .ac-tier { font-family: var(--font-mono); font-size: 11px; color: #2f8f5d; border: 1px solid #2f8f5d; border-radius: 999px; padding: 3px 10px; }
  .ac-name { display: block; font-family: var(--font-display); font-size: 21px; letter-spacing: -.02em; }
  .ac-desc { color: var(--muted); font-size: 13px; line-height: 1.5; margin: 9px 0 14px;
    display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
  .ac-axes { display: flex; flex-direction: column; gap: 5px; margin-bottom: 14px; }
  .ac-axes span { height: 4px; background: var(--grid); border-radius: 999px; overflow: hidden; }
  .ac-axes i { display: block; height: 100%; background: var(--accent); border-radius: 999px; }
  .ac-pl { font-family: var(--font-mono); font-size: 11px; color: var(--muted); }

  .seal { position: absolute; top: -38px; right: -30px; z-index: 3; width: 122px; height: 122px; }
  .seal-disc { position: absolute; inset: 7px; border-radius: 50%; background: var(--paper); border: 1.5px dashed var(--hair); }
  .seal-ring { position: absolute; inset: 0; width: 100%; height: 100%; animation: sealspin 22s linear infinite; }
  .seal-txt { font-family: var(--font-mono); font-size: 9px; letter-spacing: .05em; fill: var(--accent-text); font-weight: 600;
    text-anchor: middle; dominant-baseline: central; }
  .seal-dot { fill: var(--accent); }
  .seal-core { position: absolute; inset: 0; margin: auto; width: 68px; height: 68px; border-radius: 50%;
    background: var(--accent); color: var(--paper); display: grid; place-items: center;
    box-shadow: 0 6px 18px -6px var(--accent-soft); }
  :root[data-theme='dark'] .ac-tier { color: #8fb89a; border-color: color-mix(in srgb, #8fb89a 45%, var(--hair)); }

  @keyframes hfloat { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-12px); } }
  @keyframes sealspin { to { transform: rotate(360deg); } }
  @media (prefers-reduced-motion: reduce) { .art-stack, .seal-ring { animation: none; } }

  @media (max-width: 920px) {
    .herowrap { grid-template-columns: 1fr; }
    .hero-art { display: none; }
  }
</style>
<script>
  // Signature: lightweight parallax seam on the hero grid. rAF-throttled, reduced-motion safe.
  const grid = document.querySelector<HTMLElement>('[data-hero-grid]');
  if (grid && !matchMedia('(prefers-reduced-motion: reduce)').matches) {
    let ticking = false;
    const update = () => {
      grid.style.transform = `translate3d(0, ${window.scrollY * 0.12}px, 0)`;
      ticking = false;
    };
    addEventListener('scroll', () => {
      if (!ticking) { requestAnimationFrame(update); ticking = true; }
    }, { passive: true });
  }
</script>
