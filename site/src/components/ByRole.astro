---
const roles = [
  { name: 'Marketing', plugin: 'equipt-marketing', d: 'Ad copy, SEO audits, social, email sequences, funnels, landing pages.' },
  { name: 'Sales & outreach', plugin: 'equipt-marketing', d: 'Cold DMs & emails, call scripts, follow-ups, proposals, objection handling.' },
  { name: 'Founders & ops', plugin: 'equipt-business', d: 'Pitches, hiring, pricing, finance models, SOPs, legal, e-commerce.' },
  { name: 'Content & creators', plugin: 'equipt-content', d: 'Blog posts, newsletters, scripts, course outlines, repurposing.' },
  { name: 'Customer & support', plugin: 'equipt-business', d: 'Support replies, help docs, onboarding, retention, win-backs.' },
  { name: 'Data & analytics', plugin: 'equipt-data', d: 'Dashboards, SQL, metric definitions, analytics narratives.' },
];
---
<section class="byrole"><div class="wrap">
  <p class="kicker">Built for the way you work</p>
  <h2 class="serif">Whatever you run, there’s a skill <i>for it</i>.</h2>
  <div class="grid">
    {roles.map((r) => (
      <a class="rcard" href={`/catalog/${r.plugin}`}>
        <h3>{r.name}</h3>
        <p>{r.d}</p>
        <span class="explore mono">Explore →</span>
      </a>
    ))}
  </div>
</div></section>
<style>
  .byrole { padding: 88px 0; border-top: 1px solid var(--hair); }
  .serif { font-family: var(--font-serif); font-size: clamp(28px, 4vw, 38px); letter-spacing: .02em; margin: 6px 0 34px; }
  .serif i { color: var(--accent); }
  .grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; }
  .rcard { display: flex; flex-direction: column; border: 1px solid var(--hair); border-radius: 14px; padding: 22px; background: var(--paper);
    transition: border-color .15s ease, transform .15s ease, box-shadow .15s ease; }
  .rcard:hover { border-color: var(--accent); transform: translateY(-3px); box-shadow: 0 14px 30px -22px var(--accent-soft); }
  .rcard h3 { font-family: var(--font-display); font-size: 18px; letter-spacing: -.01em; }
  .rcard p { color: var(--muted); font-size: 13.5px; line-height: 1.55; margin: 9px 0 16px; }
  .explore { margin-top: auto; font-size: 12px; color: var(--accent-text); }
  @media (max-width: 860px) { .grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 540px) { .grid { grid-template-columns: 1fr; } }
</style>
