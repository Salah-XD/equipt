---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import ProofBar from '../components/ProofBar.astro';
import FeaturedAssets from '../components/FeaturedAssets.astro';
import DemoCompare from '../components/DemoCompare.astro';
import Finder from '../components/Finder.astro';
import TrustSection from '../components/TrustSection.astro';
import PluginGrid from '../components/PluginGrid.astro';
import InstallTabs from '../components/InstallTabs.astro';
import HowItWorks from '../components/HowItWorks.astro';
import CatalogTeaser from '../components/CatalogTeaser.astro';
import Footer from '../components/Footer.astro';
import Motion from '../components/Motion.astro';
import { loadAssets } from '../lib/catalog';
const assets = await loadAssets();
const site = (Astro.site?.href ?? 'https://equipt-agent.vercel.app/').replace(/\/$/, '');
const jsonld = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization', '@id': `${site}/#org`, name: 'Equipt', url: `${site}/`,
      logo: `${site}/favicon.svg`,
      sameAs: ['https://github.com/Salah-XD/equipt', 'https://www.npmjs.com/package/@equipt/cli'],
    },
    {
      '@type': 'WebSite', '@id': `${site}/#website`, url: `${site}/`, name: 'Equipt',
      description: 'Verified marketplace of AI skills & agents for founders & operators.',
      publisher: { '@id': `${site}/#org` },
      potentialAction: {
        '@type': 'SearchAction',
        target: { '@type': 'EntryPoint', urlTemplate: `${site}/catalog?q={search_term_string}` },
        'query-input': 'required name=search_term_string',
      },
    },
  ],
};
---
<Base title="Equipt — skills & agents for every AI assistant" jsonld={jsonld}>
  <main id="main">
    <Hero total={assets.length} />
    <div data-reveal><ProofBar total={assets.length} /></div>
    <div data-reveal><HowItWorks /></div>
    <div data-reveal><FeaturedAssets /></div>
    <div data-reveal><DemoCompare /></div>
    <div data-reveal><Finder /></div>
    <div data-reveal><TrustSection /></div>
    <div data-reveal><PluginGrid /></div>
    <div data-reveal><InstallTabs /></div>
    <div data-reveal><CatalogTeaser total={assets.length} /></div>
  </main>
  <Footer />
  <Motion />
</Base>
