---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import { loadAssets } from '../lib/catalog';
const assets = await loadAssets();
const chips = ['code-reviewer', 'seo-strategist', 'instagram-carousel', 'pricing-strategist', 'api-designer', 'cold-outreach-writer'];
---
<Base title="Equipt — skills & agents for every AI assistant">
  <Hero chips={chips} total={assets.length} />
</Base>
