---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import ProofBar from '../components/ProofBar.astro';
import PluginGrid from '../components/PluginGrid.astro';
import InstallTabs from '../components/InstallTabs.astro';
import CatalogTeaser from '../components/CatalogTeaser.astro';
import Footer from '../components/Footer.astro';
import Motion from '../components/Motion.astro';
import { loadAssets } from '../lib/catalog';
const assets = await loadAssets();
---
<Base title="Equipt — skills & agents for every AI assistant">
  <Hero total={assets.length} />
  <div data-reveal><ProofBar total={assets.length} /></div>
  <div data-reveal><PluginGrid /></div>
  <div data-reveal><InstallTabs /></div>
  <div data-reveal><CatalogTeaser total={assets.length} /></div>
  <Footer />
  <Motion />
</Base>
