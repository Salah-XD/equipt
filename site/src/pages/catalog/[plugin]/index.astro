---
import Base from '../../../layouts/Base.astro';
import Footer from '../../../components/Footer.astro';
import { loadAssets, resolveRepoRoot } from '../../../lib/catalog';
import { loadScoreIndex } from '../../../lib/scores';
import { readFile } from 'node:fs/promises';
import { join } from 'node:path';

export async function getStaticPaths() {
  const root = await resolveRepoRoot();
  const cfg = JSON.parse(await readFile(join(root, 'plugins.config.json'), 'utf8')) as {
    plugins: Record<string, { description: string }>;
  };
  const assets = await loadAssets(root);
  const scores = await loadScoreIndex(root);

  return Object.entries(cfg.plugins).map(([name, c]) => {
    const items = assets
      .filter((a) => a.plugin === name)
      .map((a) => ({
        slug: a.slug,
        name: a.name,
        kind: a.kind,
        description: a.description,
        readiness: scores.get(a.slug)?.readiness ?? null,
        tier: scores.get(a.slug)?.tier ?? null,
      }))
      .sort((x, y) => (y.readiness ?? 0) - (x.readiness ?? 0) || x.name.localeCompare(y.name));

    const skills = items.filter((i) => i.kind === 'skill').length;
    const scored = items.filter((i) => i.readiness != null) as Array<{ readiness: number }>;
    const avg = scored.length ? Math.round(scored.reduce((s, i) => s + i.readiness, 0) / scored.length) : null;

    return {
      params: { plugin: name },
      props: { plugin: name, description: c.description, items, skills, agents: items.length - skills, avg },
    };
  });
}

const { plugin, description, items, skills, agents, avg } = Astro.props;
const short = plugin.replace(/^equipt-/, '');
const label = short.charAt(0).toUpperCase() + short.slice(1);
const bundle = `${plugin}-skills.zip`;
const pluginZip = `${plugin}.zip`;
const pluginZipUrl = `https://github.com/Salah-XD/equipt/releases/latest/download/${pluginZip}`;
const ccLines = `/plugin marketplace add Salah-XD/equipt\n/plugin install ${plugin}`;
const cliLines = `npx @equipt/cli init\nnpx @equipt/cli add ${plugin}`;
---
<Base title={`${label} skills & agents — Equipt`} description={description}>
  <main id="main" class="plugin wrap">
    <a href="/catalog" class="kicker back">← Catalog</a>

    <header class="phead">
      <p class="eyebrow mono">Plugin · {plugin}</p>
      <h1>{label}</h1>
      <p class="desc">{description}</p>
      <div class="stats">
        <span><b>{skills}</b> skills</span>
        <span><b>{agents}</b> agents</span>
        {avg != null && <span><b>{avg}</b> avg readiness</span>}
      </div>

      <div class="install">
        <span class="kicker">Add the {label} pack</span>
        <div class="itabs" role="tablist" aria-label="Install instructions">
          <button class="itab on" type="button" data-itab="web" role="tab" aria-selected="true">claude.ai / desktop</button>
          <button class="itab" type="button" data-itab="cc" role="tab" aria-selected="false">Claude Code</button>
          <button class="itab" type="button" data-itab="cli" role="tab" aria-selected="false">Equipt CLI</button>
        </div>
        <div class="ipanel" data-ipanel="web" role="tabpanel">
          <ol class="steps">
            <li>The whole {label} plugin — all {skills} skills, packaged and ready to upload.
              <a class="dl" href={pluginZipUrl} download>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3v12m0 0l-4-4m4 4l4-4M4 19h16"/></svg>
                {pluginZip}
              </a>
            </li>
            <li>In <b>claude.ai</b> or <b>Claude desktop</b>: <b>Customize → Personal plugins (+) → Create plugin → Upload plugin</b>, and select the zip.</li>
            <li>Every {label} skill is live in your chats — no code, all at once.</li>
          </ol>
          <p class="hint">Plugins need a <b>paid plan</b> (Pro / Max / Team).{agents > 0 ? ` Bonus: its ${agents} agents install too — they activate in Cowork & Claude Code (greyed out in normal chat).` : ''} Just want one skill? Open it below and use its <b>Upload skill</b> zip (works on Free too).</p>
        </div>
        <div class="ipanel" data-ipanel="cc" role="tabpanel" hidden>
          <div class="cmd">
            <pre data-copy><code>{ccLines}</code></pre>
            <button class="copy" type="button" aria-label="Copy Claude Code install">Copy</button>
          </div>
          <p class="hint">Installs all {skills + agents} — skills &amp; agents. Prefer files? Download <a href="https://github.com/Salah-XD/equipt/releases"><b>{bundle}</b></a> and unzip into <code>~/.claude/</code> — it expands to <code>~/.claude/skills/</code>.</p>
        </div>
        <div class="ipanel" data-ipanel="cli" role="tabpanel" hidden>
          <div class="cmd">
            <pre data-copy><code>{cliLines}</code></pre>
            <button class="copy" type="button" aria-label="Copy Equipt CLI install">Copy</button>
          </div>
          <p class="hint">For your own Claude Code project.</p>
        </div>
      </div>
    </header>

    <div class="grid">
      {items.map((i) => (
        <a class="card" href={`/catalog/${i.slug}`}>
          <div class="ctop">
            <span class={`k k-${i.kind}`}>{i.kind}</span>
            <span class="rt">
              {i.tier === 'field-ready' && <span class="tierbadge t-field-ready">Field-Ready</span>}
              {i.tier === 'certified' && <span class="tierbadge t-certified">Certified</span>}
              {i.readiness != null && <span class="score mono">{i.readiness}</span>}
            </span>
          </div>
          <strong>{i.name}</strong>
          <p>{i.description}</p>
        </a>
      ))}
    </div>
  </main>
  <Footer />
</Base>
<style>
  .plugin { padding: 36px 22px 72px; max-width: 1120px; }
  .back { display: inline-block; margin-bottom: 22px; }
  .phead { border-bottom: 1px solid var(--hair); padding-bottom: 28px; margin-bottom: 28px; }
  .eyebrow { font-size: 12px; letter-spacing: .12em; text-transform: uppercase; color: var(--muted); margin-bottom: 10px; }
  h1 { font-family: var(--font-display); font-size: clamp(34px, 6vw, 56px); letter-spacing: -.03em; }
  .desc { font-size: 18px; line-height: 1.55; color: var(--muted); max-width: 64ch; margin-top: 10px; }
  .stats { display: flex; flex-wrap: wrap; gap: 22px; margin-top: 18px; font-family: var(--font-mono); font-size: 13px; color: var(--muted); }
  .stats b { font-family: var(--font-display); color: var(--ink); font-size: 16px; }

  .install { margin-top: 26px; max-width: 560px; }
  .install .kicker { display: block; margin-bottom: 10px; }
  .itabs { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 13px; }
  .itab { font-family: var(--font-mono); font-size: 11.5px; padding: 6px 11px; border: 1px solid var(--hair); border-radius: 7px;
    background: transparent; color: var(--muted); cursor: pointer; transition: color .15s ease, border-color .15s ease, background-color .15s ease; }
  .itab:hover { color: var(--ink); border-color: var(--accent); }
  .itab.on { color: var(--paper); background: var(--ink); border-color: var(--ink); }
  .ipanel[hidden] { display: none; }
  /* Install steps as a vertical roadmap — numbered nodes threaded on a rail. */
  .steps { list-style: none; margin: 2px 0 0; padding: 0; position: relative; counter-reset: step;
    font-size: 13.5px; line-height: 1.7; color: var(--ink); }
  /* connector from each node down to the next — anchored per-step so it never overshoots the last node */
  .steps li:not(:last-child)::after { content: ''; position: absolute; left: 12px; top: 24.5px; bottom: -1px; width: 2px;
    background: color-mix(in srgb, var(--accent) 24%, var(--hair)); }
  .steps li { position: relative; counter-increment: step; padding: 0 0 20px 40px; }
  .steps li:last-child { padding-bottom: 0; }
  /* top centers the 26px node on the first text line (line-height 1.7 × 13.5px = 22.95px) */
  .steps li::before { content: counter(step); position: absolute; left: 0; top: -1.5px; z-index: 1;
    width: 26px; height: 26px; border-radius: 50%; display: grid; place-items: center;
    font-family: var(--font-mono); font-size: 12px; color: var(--accent-text);
    background: var(--paper); border: 1px solid var(--hair); }
  .steps li:last-child::before { content: '✓'; color: var(--paper); background: var(--accent); border-color: var(--accent); }
  .steps b { font-weight: 600; }
  .steps a:not(.dl) { color: var(--accent-text); text-decoration: underline; text-underline-offset: 2px; }
  .steps .dl { display: flex; width: fit-content; align-items: center; gap: 7px; margin-top: 10px; font-family: var(--font-mono);
    font-size: 12.5px; padding: 9px 14px; border-radius: 9px; color: var(--paper); background: var(--ink);
    border: 1px solid var(--ink); text-decoration: none; font-weight: 600;
    transition: background-color .16s ease, border-color .16s ease, transform .16s ease; }
  .steps .dl:hover { background: var(--accent); border-color: var(--accent); color: var(--paper); transform: translateY(-1px); }
  .steps .dl svg { width: 13px; height: 13px; }
  .hint { margin-top: 9px; color: var(--muted); font-size: 12px; }
  .hint b { color: var(--ink); font-weight: 600; }
  .hint a { color: var(--accent-text); text-decoration: underline; text-underline-offset: 2px; }
  .hint code { font-family: var(--font-mono); font-size: .92em; }
  .cmd { position: relative; }
  .cmd pre { background: var(--paper); border: 1px solid var(--hair); border-radius: 10px; padding: 14px 84px 14px 16px;
    overflow: auto; font-family: var(--font-mono); font-size: 13px; line-height: 1.6; color: var(--ink); white-space: pre; }
  .copy { position: absolute; top: 10px; right: 10px; font-family: var(--font-mono); font-size: 11px; letter-spacing: .04em;
    padding: 6px 11px; border-radius: 7px; border: 1px solid var(--hair); background: var(--page); color: var(--muted); cursor: pointer;
    transition: border-color .15s, color .15s; }
  .copy:hover { border-color: var(--accent); color: var(--accent-text); }

  .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 13px; }
  .card { display: block; border: 1px solid var(--hair); border-radius: 13px; padding: 17px 18px; background: var(--paper);
    transition: border-color .15s ease, transform .15s ease, box-shadow .15s ease; }
  .card:hover { border-color: var(--accent); transform: translateY(-2px); box-shadow: 0 12px 26px -20px var(--accent-soft); }
  .ctop { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px; }
  .k { font-family: var(--font-mono); font-size: 10.5px; text-transform: uppercase; letter-spacing: .05em;
    padding: 3px 8px; border-radius: 6px; border: 1px solid var(--hair); }
  .k-skill { color: var(--accent-text); }
  .k-agent { color: var(--ink); }
  .rt { display: inline-flex; align-items: center; gap: 7px; }
  .tierbadge { font-family: var(--font-mono); font-size: 10px; padding: 2px 7px; border-radius: 999px; border: 1px solid var(--hair); white-space: nowrap; }
  .t-certified { color: var(--accent-text); border-color: var(--accent); }
  .t-field-ready { color: #2f8f5d; border-color: #2f8f5d; }
  .score { font-size: 12.5px; color: var(--muted); }
  .card strong { font-family: var(--font-display); font-size: 16px; letter-spacing: -.01em; }
  .card p { color: var(--muted); font-size: 13px; line-height: 1.5; margin-top: 7px;
    display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
</style>
<script>
  const itabs = document.querySelectorAll<HTMLButtonElement>('.itab');
  const ipanels = document.querySelectorAll<HTMLElement>('.ipanel');
  itabs.forEach((tab) => tab.addEventListener('click', () => {
    itabs.forEach((t) => { t.classList.remove('on'); t.setAttribute('aria-selected', 'false'); });
    tab.classList.add('on');
    tab.setAttribute('aria-selected', 'true');
    ipanels.forEach((p) => (p.hidden = p.dataset.ipanel !== tab.dataset.itab));
  }));

  document.querySelectorAll<HTMLButtonElement>('.copy').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const pre = btn.parentElement?.querySelector('pre[data-copy]');
      if (!pre) return;
      try {
        await navigator.clipboard.writeText(pre.textContent ?? '');
        const prev = btn.textContent;
        btn.textContent = 'Copied';
        setTimeout(() => { btn.textContent = prev; }, 1400);
      } catch {}
    });
  });
</script>
