---
import Base from '../../../layouts/Base.astro';
import Footer from '../../../components/Footer.astro';
import { loadAssets } from '../../../lib/catalog';
import { marked } from 'marked';

export async function getStaticPaths() {
  const assets = await loadAssets();
  return assets.map((asset) => ({ params: { plugin: asset.plugin, name: asset.name }, props: { asset } }));
}
const { asset } = Astro.props;
// Skill/agent bodies usually open with their own `# Title`. Lift it out so the
// page has a single <h1> (the title) and the body's sub-headings stay in order.
const titleMatch = asset.body.match(/^\s*#\s+(.+?)\s*\r?\n/);
const displayTitle = titleMatch ? titleMatch[1].trim() : asset.name;
const body = titleMatch ? asset.body.slice(titleMatch[0].length) : asset.body;
const bodyHtml = await marked.parse(body);
const surfaces = asset.kind === 'skill'
  ? 'Claude Code ┬Ę claude.ai ┬Ę Claude desktop'
  : 'Claude Code';
---
<Base title={`${displayTitle} ŌĆö Equipt`} description={asset.description}>
  <main class="wrap" style="padding:40px 22px 70px;max-width:820px">
    <a href="/catalog" class="kicker">ŌåÉ Catalog</a>
    <div class="meta">
      <span class="k mono">{asset.kind}</span>
      <a class="pl mono" href={`/catalog?plugin=${asset.plugin}`}>{asset.plugin}</a>
    </div>
    <h1>{displayTitle}</h1>
    <p class="slug mono">{asset.name}</p>
    <p class="desc">{asset.description}</p>
    <p class="kicker">Works in {surfaces}</p>
    <article class="prose" set:html={bodyHtml} />
    <p class="src"><a href={`https://github.com/Salah-XD/equipt/blob/main/plugins/${asset.plugin}/${asset.kind === 'skill' ? `skills/${asset.name}/SKILL.md` : `agents/${asset.name}.md`}`}>View source on GitHub ŌåÆ</a></p>
  </main>
  <Footer />
</Base>
<style>
  .meta { display: flex; gap: 10px; margin-top: 18px; }
  .k { color: var(--accent-text); text-transform: uppercase; font-size: 12px; }
  .pl { color: var(--muted); font-size: 12px; }
  h1 { font-family: var(--font-display); font-size: 40px; margin: 8px 0 2px; letter-spacing: -.02em; }
  .slug { color: var(--muted); font-size: 13px; margin-bottom: 14px; }
  .desc { color: var(--muted); font-size: 17px; line-height: 1.5; margin-bottom: 18px; }
  .prose { margin-top: 26px; line-height: 1.7; }
  .prose :global(h1), .prose :global(h2), .prose :global(h3) { font-family: var(--font-display); margin: 22px 0 10px; }
  .prose :global(pre) { background: var(--paper); border: 1px solid var(--hair); border-radius: 10px; padding: 14px; overflow: auto; font-family: var(--font-mono); font-size: 13px; }
  .prose :global(code) { font-family: var(--font-mono); font-size: .9em; }
  .prose :global(table) { width: 100%; border-collapse: collapse; }
  .prose :global(th), .prose :global(td) { border: 1px solid var(--hair); padding: 8px; text-align: left; }
  .src { margin-top: 30px; }
  .src a { color: var(--accent-text); }
  .prose :global(a) { color: var(--accent-text); text-decoration: underline; text-underline-offset: 2px; }
</style>
